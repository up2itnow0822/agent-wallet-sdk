# Agent Wallet SDK — Environment Variables
# Copy to .env and fill in your values

# Required: Your agent's private key (NEVER commit this)
AGENT_PRIVATE_KEY=0x...

# Required: Your agent's wallet address
AGENT_WALLET_ADDRESS=0x...

# Chain configuration
CHAIN_NAME=base           # base, ethereum, arbitrum, optimism, polygon, base-sepolia
RPC_URL=                  # Optional: custom RPC URL (defaults to public RPC)

# Spending limits (optional, recommended)
SPEND_LIMIT_PER_TX=10     # Max USD per transaction
SPEND_LIMIT_DAILY=100     # Max USD per day
SPEND_ALLOWLIST=           # Comma-separated recipient addresses

# x402 configuration (optional)
X402_SUPPORTED_NETWORKS=base,base-sepolia
X402_GLOBAL_DAILY_LIMIT=50
X402_PER_REQUEST_MAX=10

# Payments mode
PAYMENTS_MODE=dry_run     # dry_run | live
